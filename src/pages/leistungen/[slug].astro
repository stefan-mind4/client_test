---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const leistungen = await import.meta.glob('../../content/leistungen/*.json');
  const paths = [];
  for (const [path, mod] of Object.entries(leistungen)) {
    const content = await (mod as () => Promise<any>)();
    const slug = path.split('/').pop()?.replace('.json', '');
    paths.push({ params: { slug }, props: { content } });
  }
  return paths;
}

const { content } = Astro.props;
---

<Layout title={content.meta_title} description={content.meta_description} ogImage={content.og_image}>

<!-- HEADER (same as main page) -->
<header class="fixed top-0 left-0 right-0 z-50 bg-[#0f2c4e] shadow-lg">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-18 py-4">
    <a href="/" class="flex flex-col leading-none text-white">
      <span class="font-serif text-xl font-bold tracking-tight">HSOA</span>
      <span class="text-[10px] tracking-[0.2em] uppercase text-[#7eb8e8] font-light">Rechtsanwälte</span>
    </a>
    <nav class="hidden md:flex items-center gap-8">
      <a href="/#sozietaet" class="text-sm text-white/75 hover:text-white transition-colors">Sozietät</a>
      <a href="/#kompetenz" class="text-sm text-white/75 hover:text-white transition-colors">Kompetenz</a>
      <a href="/#partner" class="text-sm text-white/75 hover:text-white transition-colors">Partner</a>
      <a href="/#karriere" class="text-sm text-white/75 hover:text-white transition-colors">Karriere</a>
      <a href="/#kontakt" class="text-sm text-white/75 hover:text-white transition-colors">Kontakt</a>
      <a href="/#kontakt" class="ml-2 px-5 py-2.5 bg-[#4a9fd4] text-white text-sm font-semibold rounded-sm hover:bg-[#3a8fc4] transition-colors">Beratung anfragen</a>
    </nav>
  </div>
</header>

<!-- HERO der Leistungsseite -->
<section class="relative min-h-[92vh] flex items-end pb-0 overflow-hidden pt-[72px]" style="background: linear-gradient(150deg, #0a1e35 0%, #0f2c4e 50%, #143660 100%)">
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(#4a9fd4 1px, transparent 1px), linear-gradient(90deg, #4a9fd4 1px, transparent 1px); background-size: 64px 64px;"></div>

  <div class="relative max-w-7xl mx-auto px-6 pt-16 pb-0 w-full">
    <div class="max-w-3xl pb-16">
      <div class="flex items-center gap-2 mb-8 text-white/40 text-xs">
        <a href="/" class="hover:text-white/60 transition-colors">HSOA Rechtsanwälte</a>
        <span>/</span>
        <span class="text-[#4a9fd4]">{content.hero_breadcrumb}</span>
      </div>
      <div class="inline-flex items-center gap-2 mb-5 px-3 py-1.5 bg-[#4a9fd4]/15 border border-[#4a9fd4]/30 rounded-sm">
        <span class="text-lg">{content.hero_icon}</span>
        <span class="text-[#4a9fd4] text-xs tracking-[0.2em] uppercase font-medium">{content.hero_eyebrow}</span>
      </div>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-[3.5rem] text-white leading-[1.08] mb-6" set:html={content.hero_headline}></h1>
      <p class="text-white/60 text-lg leading-relaxed mb-10 max-w-2xl">{content.hero_text}</p>

      {content.hero_bild && (
        <div class="mb-10 rounded-sm overflow-hidden">
          <img src={content.hero_bild} alt={content.hero_bild_alt || content.hero_breadcrumb} class="w-full object-cover max-h-80" />
        </div>
      )}

      <div class="flex flex-wrap gap-4 mb-12">
        <a href="#kontakt" class="flex items-center gap-2 px-7 py-3.5 bg-[#4a9fd4] text-white font-semibold text-sm rounded-sm hover:bg-[#3a8fc4] transition-colors">
          Erstgespräch vereinbaren
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="#leistungen" class="px-7 py-3.5 border border-white/20 text-white/75 text-sm rounded-sm hover:border-white/40 hover:text-white transition-colors">
          Alle Leistungen ansehen
        </a>
      </div>
      <div class="flex flex-wrap gap-6 text-white/35 text-xs border-t border-white/10 pt-6">
        {content.hero_trust_items?.map((item: string) => (
          <div class="flex items-center gap-2">
            <div class="w-1 h-1 rounded-full bg-[#4a9fd4]"></div>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="border-t border-white/10 py-5 flex flex-wrap gap-6 md:gap-10">
      <a href={`tel:${content.telefon_link}`} class="flex items-center gap-2.5 text-white/50 hover:text-white text-sm transition-colors">
        <svg width="18" height="18" fill="none" stroke="#4a9fd4" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92v2z"/></svg>
        {content.telefon}
      </a>
      <a href={`mailto:${content.email}`} class="flex items-center gap-2.5 text-white/50 hover:text-white text-sm transition-colors">
        <svg width="18" height="18" fill="none" stroke="#4a9fd4" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        {content.email}
      </a>
    </div>
  </div>
</section>

<!-- LEISTUNGEN / ACCORDION -->
<section id="leistungen" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-14">
      <div class="inline-flex items-center gap-2 mb-4">
        <div class="h-px w-8 bg-[#0f2c4e]"></div>
        <span class="text-[#0f2c4e] text-xs tracking-[0.25em] uppercase font-medium">Leistungsspektrum</span>
      </div>
      <h2 class="font-serif text-3xl md:text-4xl text-[#0f2c4e] max-w-2xl leading-tight mb-4">{content.leistungen_headline}</h2>
      <p class="text-stone-500 text-base max-w-2xl leading-relaxed">{content.leistungen_subtext}</p>
    </div>

    {content.intro_bild && (
      <div class="mb-12 rounded-sm overflow-hidden">
        <img src={content.intro_bild} alt={content.intro_bild_alt || 'Leistungsübersicht'} class="w-full object-cover max-h-64" />
      </div>
    )}

    <div class="space-y-3" id="accordion">
      {content.leistungen.map((item: {nr: string, title: string, desc: string, details: string[], bild?: string, bild_alt?: string}, i: number) => (
        <div class="border border-stone-100 rounded-sm accordion-item" data-index={i}>
          <button class="w-full flex items-center justify-between px-7 py-5 text-left accordion-btn">
            <div class="flex items-center gap-5">
              <span class="text-[11px] font-mono text-[#4a9fd4] tracking-widest">{item.nr}</span>
              <h3 class="font-serif text-lg font-semibold text-[#0f2c4e]">{item.title}</h3>
            </div>
            <svg class="text-stone-400 transition-transform duration-200 accordion-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="accordion-content hidden px-7 pb-7 pt-0 grid md:grid-cols-2 gap-8 border-t border-stone-50">
            <div class="pt-5">
              <p class="text-stone-600 text-sm leading-relaxed mb-5">{item.desc}</p>
              {item.bild && (
                <img src={item.bild} alt={item.bild_alt || item.title} class="w-full rounded-sm object-cover mb-5 aspect-video" />
              )}
              <a href="#kontakt" class="inline-flex items-center gap-2 text-sm font-semibold text-[#4a9fd4] hover:text-[#0f2c4e] transition-colors">
                Zu diesem Thema beraten lassen
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
            <div class="pt-5">
              <p class="text-xs font-medium text-stone-400 uppercase tracking-widest mb-3">Schwerpunkte</p>
              <ul class="space-y-2">
                {item.details.map((d: string) => (
                  <li class="flex items-center gap-2.5">
                    <svg width="15" height="15" fill="none" stroke="#4a9fd4" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                    <span class="text-stone-600 text-sm">{d}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FÜR WEN -->
<section class="py-24 bg-[#f8f5f0]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-14">
      <div class="inline-flex items-center gap-2 mb-4">
        <div class="h-px w-8 bg-[#0f2c4e]"></div>
        <span class="text-[#0f2c4e] text-xs tracking-[0.25em] uppercase font-medium">Für wen wir arbeiten</span>
      </div>
      <h2 class="font-serif text-3xl md:text-4xl text-[#0f2c4e] max-w-2xl leading-tight mb-4">{content.zielgruppen_headline}</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {content.zielgruppen?.map((z: {icon: string, title: string, pain: string, value: string, tags: string[], bild?: string, bild_alt?: string}) => (
        <div class="bg-white border border-stone-100 rounded-sm p-7 hover:border-[#4a9fd4]/40 hover:shadow-sm transition-all">
          <div class="flex items-start gap-4 mb-5">
            <div class="text-3xl">{z.icon}</div>
            <h3 class="font-serif text-xl text-[#0f2c4e] font-semibold leading-tight pt-1">{z.title}</h3>
          </div>
          {z.bild && (
            <img src={z.bild} alt={z.bild_alt || z.title} class="w-full rounded-sm object-cover aspect-video mb-5" />
          )}
          <div class="space-y-4 mb-5">
            <div>
              <p class="text-[10px] font-medium text-stone-400 uppercase tracking-widest mb-1.5">Typische Herausforderung</p>
              <p class="text-stone-600 text-sm leading-relaxed">{z.pain}</p>
            </div>
            <div class="border-l-2 border-[#4a9fd4] pl-4">
              <p class="text-[10px] font-medium text-[#4a9fd4] uppercase tracking-widest mb-1.5">Unser Beitrag</p>
              <p class="text-stone-700 text-sm leading-relaxed">{z.value}</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {z.tags.map((tag: string) => (
              <span class="text-[10px] bg-stone-50 text-stone-500 border border-stone-100 px-2 py-0.5">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- PROZESS -->
<section class="py-24 bg-[#0f2c4e]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-14">
      <div class="inline-flex items-center gap-2 mb-4">
        <div class="h-px w-8 bg-[#4a9fd4]"></div>
        <span class="text-[#4a9fd4] text-xs tracking-[0.25em] uppercase font-medium">Unser Prozess</span>
      </div>
      <h2 class="font-serif text-3xl md:text-4xl text-white max-w-2xl leading-tight mb-4">{content.prozess_headline}</h2>
      <p class="text-white/50 text-base max-w-2xl leading-relaxed">{content.prozess_subtext}</p>
    </div>
    <div class="grid md:grid-cols-5 gap-8">
      {content.prozess_schritte?.map((s: {step: string, icon: string, title: string, desc: string}, i: number) => (
        <div class="relative">
          <div class="relative z-10 w-20 h-20 rounded-sm bg-[#071528] border border-[#4a9fd4]/30 flex flex-col items-center justify-center mb-5 mx-auto md:mx-0">
            <span class="text-2xl mb-0.5">{s.icon}</span>
            <span class="text-[10px] text-[#4a9fd4] font-mono tracking-widest">{s.step}</span>
          </div>
          <h3 class="font-semibold text-white text-sm mb-2 leading-tight">{s.title}</h3>
          <p class="text-white/45 text-xs leading-relaxed">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FAQ -->
<section id="faq" class="py-24 bg-white">
  <div class="max-w-4xl mx-auto px-6">
    <div class="mb-12">
      <div class="inline-flex items-center gap-2 mb-4">
        <div class="h-px w-8 bg-[#0f2c4e]"></div>
        <span class="text-[#0f2c4e] text-xs tracking-[0.25em] uppercase font-medium">Häufige Fragen</span>
      </div>
      <h2 class="font-serif text-3xl md:text-4xl text-[#0f2c4e] leading-tight">{content.faq_headline}</h2>
    </div>
    <div class="space-y-2" id="faq-accordion">
      {content.faq?.map((item: {q: string, a: string}, i: number) => (
        <div class="border border-stone-100 rounded-sm faq-item" data-index={i}>
          <button class="w-full flex items-center justify-between px-6 py-5 text-left gap-4 faq-btn">
            <span class="text-sm font-medium text-[#0f2c4e]">{item.q}</span>
            <svg class="text-stone-400 shrink-0 transition-transform duration-200 faq-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-content hidden px-6 pb-5 pt-0 border-t border-stone-50">
            <p class="text-stone-600 text-sm leading-relaxed pt-4">{item.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- KONTAKT -->
<section id="kontakt" class="py-24 bg-[#f8f5f0]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-5 gap-12 items-start">
      <div class="md:col-span-2">
        <div class="inline-flex items-center gap-2 mb-4">
          <div class="h-px w-8 bg-[#0f2c4e]"></div>
          <span class="text-[#0f2c4e] text-xs tracking-[0.25em] uppercase font-medium">Kontakt</span>
        </div>
        <h2 class="font-serif text-3xl md:text-4xl text-[#0f2c4e] leading-tight mb-4">{content.kontakt_headline}</h2>
        <p class="text-stone-600 text-sm leading-relaxed mb-8">{content.kontakt_text}</p>
        <div class="space-y-4 mb-8">
          <a href={`tel:${content.telefon_link}`} class="flex items-center gap-3 p-4 bg-white border border-stone-100 rounded-sm hover:border-[#4a9fd4] transition-colors group">
            <svg width="18" height="18" fill="none" stroke="#4a9fd4" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92v2z"/></svg>
            <div>
              <p class="text-[10px] text-stone-400 uppercase tracking-wide">Direktlinie</p>
              <p class="text-[#0f2c4e] font-semibold text-sm">{content.telefon}</p>
            </div>
          </a>
          <a href={`mailto:${content.email}`} class="flex items-center gap-3 p-4 bg-white border border-stone-100 rounded-sm hover:border-[#4a9fd4] transition-colors group">
            <svg width="18" height="18" fill="none" stroke="#4a9fd4" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <div>
              <p class="text-[10px] text-stone-400 uppercase tracking-wide">E-Mail</p>
              <p class="text-[#0f2c4e] font-semibold text-sm">{content.email}</p>
            </div>
          </a>
        </div>
        {content.kontakt_zitat && (
          <div class="p-5 bg-[#0f2c4e] rounded-sm">
            <p class="text-white/90 font-serif text-base leading-snug mb-1">„{content.kontakt_zitat}"</p>
            {content.kontakt_zitat_autor && <p class="text-white/40 text-xs mt-2">{content.kontakt_zitat_autor}</p>}
          </div>
        )}
      </div>
      <div class="md:col-span-3 bg-white border border-stone-100 rounded-sm p-8 shadow-sm">
        <p class="text-xs font-medium text-stone-400 uppercase tracking-widest mb-5">Ihre Anfrage</p>
        <form class="space-y-4" netlify>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-medium text-stone-500 uppercase tracking-wide mb-1.5">Name *</label>
              <input name="name" required class="w-full px-4 py-3 border border-stone-200 rounded-sm text-sm focus:outline-none focus:border-[#4a9fd4] bg-white transition-colors" placeholder="Ihr vollständiger Name" />
            </div>
            <div>
              <label class="block text-xs font-medium text-stone-500 uppercase tracking-wide mb-1.5">Unternehmen</label>
              <input name="firma" class="w-full px-4 py-3 border border-stone-200 rounded-sm text-sm focus:outline-none focus:border-[#4a9fd4] bg-white transition-colors" placeholder="Firmenname" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-medium text-stone-500 uppercase tracking-wide mb-1.5">E-Mail *</label>
              <input type="email" name="email" required class="w-full px-4 py-3 border border-stone-200 rounded-sm text-sm focus:outline-none focus:border-[#4a9fd4] bg-white transition-colors" placeholder="ihre@email.at" />
            </div>
            <div>
              <label class="block text-xs font-medium text-stone-500 uppercase tracking-wide mb-1.5">Telefon</label>
              <input name="telefon" class="w-full px-4 py-3 border border-stone-200 rounded-sm text-sm focus:outline-none focus:border-[#4a9fd4] bg-white transition-colors" placeholder="+43 ..." />
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-stone-500 uppercase tracking-wide mb-1.5">Beschreibung *</label>
            <textarea name="nachricht" required rows={4} class="w-full px-4 py-3 border border-stone-200 rounded-sm text-sm focus:outline-none focus:border-[#4a9fd4] bg-white resize-none transition-colors" placeholder="Schildern Sie uns kurz Ihr Anliegen ..."></textarea>
          </div>
          <button type="submit" class="w-full py-3.5 bg-[#0f2c4e] text-white text-sm font-semibold rounded-sm hover:bg-[#0a1e35] transition-colors flex items-center justify-center gap-2">
            Anfrage unverbindlich absenden
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<footer class="bg-[#071528] py-8 text-white/30 text-xs">
  <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between gap-4">
    <div>
      <span class="font-serif text-white/60 font-bold">HSOA Rechtsanwälte</span>
      <span class="mx-2">·</span>
      {content.adresse}
    </div>
    <div class="flex gap-5">
      <a href="/" class="hover:text-white/60 transition-colors">Zur Kanzlei-Website</a>
      <a href="/impressum" class="hover:text-white/60 transition-colors">Impressum</a>
      <a href="/datenschutz" class="hover:text-white/60 transition-colors">Datenschutz</a>
    </div>
  </div>
</footer>

</Layout>

<script>
  // Accordion
  document.querySelectorAll('.accordion-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.accordion-item');
      const content = item?.querySelector('.accordion-content');
      const icon = btn.querySelector('.accordion-icon');
      const isOpen = !content?.classList.contains('hidden');
      document.querySelectorAll('.accordion-content').forEach(c => c.classList.add('hidden'));
      document.querySelectorAll('.accordion-icon').forEach(i => i.classList.remove('rotate-180'));
      document.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('border-[#4a9fd4]', 'shadow-sm'));
      if (!isOpen) {
        content?.classList.remove('hidden');
        icon?.classList.add('rotate-180');
        item?.classList.add('border-[#4a9fd4]', 'shadow-sm');
      }
    });
  });
  // FAQ Accordion
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const content = item?.querySelector('.faq-content');
      const icon = btn.querySelector('.faq-icon');
      const isOpen = !content?.classList.contains('hidden');
      document.querySelectorAll('.faq-content').forEach(c => c.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(i => i.classList.remove('rotate-180'));
      if (!isOpen) {
        content?.classList.remove('hidden');
        icon?.classList.add('rotate-180');
      }
    });
  });
</script>
