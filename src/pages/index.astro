---
import Layout from '../layouts/Layout.astro';
import content from '../content/home.json';
---

<Layout
  title={content.meta_title}
  description={content.meta_description}
  ogImage={content.og_image}
>

<!-- NAV -->
<header class="fixed top-0 left-0 right-0 z-50 bg-[#0f2c4e] shadow-lg">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-20">
    <a href="/" class="flex flex-col leading-none text-white">
      <span class="font-serif text-xl font-bold tracking-tight">{content.kanzlei_kuerzel}</span>
      <span class="text-[10px] tracking-[0.2em] uppercase text-[#7eb8e8] font-light">{content.kanzlei_untertitel}</span>
    </a>
    <nav class="hidden md:flex items-center gap-8">
      {content.nav_links.map((link: {label: string, href: string}) => (
        <a href={link.href} class="text-sm text-white/80 hover:text-white transition-colors tracking-wide">{link.label}</a>
      ))}
      <a href="#kontakt" class="ml-4 px-5 py-2.5 bg-white text-[#0f2c4e] text-sm font-semibold rounded-sm hover:bg-[#e8f0f8] transition-colors">
        {content.nav_cta_text}
      </a>
    </nav>
    <button id="burger" class="md:hidden text-white p-1" aria-label="Menü öffnen">
      <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>
  <div id="mobile-menu" class="hidden md:hidden bg-[#0f2c4e] border-t border-white/10 px-6 pb-6 pt-2">
    {content.nav_links.map((link: {label: string, href: string}) => (
      <a href={link.href} class="block py-3 text-white/80 hover:text-white text-sm border-b border-white/10 last:border-0">{link.label}</a>
    ))}
    <a href="#kontakt" class="mt-4 block w-full py-3 text-center bg-white text-[#0f2c4e] text-sm font-semibold rounded-sm">{content.nav_cta_text}</a>
  </div>
</header>

<!-- HERO -->
<section id="top" class="relative min-h-screen flex items-center overflow-hidden" style="background: linear-gradient(135deg, #0f2c4e 0%, #0a1e35 60%, #071528 100%)">
  <div class="absolute inset-0 opacity-5" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 40px, rgba(255,255,255,0.5) 40px, rgba(255,255,255,0.5) 41px)"></div>
  <div class="absolute left-0 top-0 bottom-0 w-1 bg-gradient-to-b from-[#4a9fd4] via-[#2d7ab5] to-transparent"></div>

  <div class="relative max-w-7xl mx-auto px-6 pt-28 pb-20 grid md:grid-cols-2 gap-16 items-center">
    <div>
      <div class="inline-flex items-center gap-2 mb-6">
        <div class="h-px w-8 bg-[#4a9fd4]"></div>
        <span class="text-[#4a9fd4] text-xs tracking-[0.25em] uppercase font-medium">{content.hero_eyebrow}</span>
      </div>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-white leading-[1.1] mb-6" set:html={content.hero_headline}></h1>
      <p class="text-white/65 text-lg leading-relaxed mb-10 max-w-lg">{content.hero_text}</p>
      <div class="flex flex-wrap gap-4">
        <a href="#kontakt" class="flex items-center gap-2 px-7 py-3.5 bg-[#4a9fd4] text-white font-semibold text-sm rounded-sm hover:bg-[#3a8fc4] transition-colors">
          {content.hero_cta_primary}
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="#kompetenz" class="px-7 py-3.5 border border-white/25 text-white/80 font-medium text-sm rounded-sm hover:border-white/50 hover:text-white transition-colors">
          {content.hero_cta_secondary}
        </a>
      </div>
      <div class="mt-12 flex items-center gap-6 text-white/40 text-xs">
        {content.hero_stats.map((s: string) => (
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-[#4a9fd4]"></div>
            <span>{s}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="hidden md:block">
      <div class="relative">
        <div class="absolute -inset-4 bg-[#4a9fd4]/10 rounded blur-3xl"></div>
        <div class="relative border border-white/10 rounded-sm p-8 bg-white/5 backdrop-blur-sm">
          <p class="text-white/50 text-xs uppercase tracking-widest mb-5">{content.kontakt_card_titel}</p>
          <div class="space-y-4">
            <a href={`tel:${content.telefon_link}`} class="flex items-center gap-3 text-white/80 hover:text-white transition-colors group">
              <span class="text-[#4a9fd4]">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92v2z"/></svg>
              </span>
              <span class="text-sm group-hover:underline">{content.telefon}</span>
            </a>
            <a href={`mailto:${content.email}`} class="flex items-center gap-3 text-white/80 hover:text-white transition-colors group">
              <span class="text-[#4a9fd4]">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
              <span class="text-sm group-hover:underline">{content.email}</span>
            </a>
            <div class="flex items-start gap-3 text-white/60">
              <span class="text-[#4a9fd4] mt-0.5">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <span class="text-sm leading-relaxed" set:html={content.adresse_html}></span>
            </div>
          </div>
          <hr class="my-6 border-white/10"/>
          <p class="text-white/40 text-xs leading-relaxed italic">{content.hero_zitat}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ÜBER UNS / SOZIETÄT -->
<section id="sozietaet" class="py-28 bg-[#f8f5f0]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div>
        <div class="inline-flex items-center gap-2 mb-5">
          <div class="h-px w-8 bg-[#0f2c4e]"></div>
          <span class="text-[#0f2c4e] text-xs tracking-[0.25em] uppercase font-medium">{content.sozietaet_eyebrow}</span>
        </div>
        <h2 class="font-serif text-3xl md:text-4xl text-[#0f2c4e] leading-tight mb-6">{content.sozietaet_headline}</h2>
        <div class="text-stone-600 text-base leading-relaxed mb-5" set:html={content.sozietaet_text}></div>
        {content.sozietaet_bild && (
          <img src={content.sozietaet_bild} alt={content.sozietaet_bild_alt || 'HSOA Kanzlei'} class="w-full rounded-sm mb-6 object-cover aspect-video" />
        )}
        <a href="#kontakt" class="inline-flex items-center gap-2 text-sm font-semibold text-[#0f2c4e] border-b-2 border-[#4a9fd4] pb-0.5 hover:text-[#4a9fd4] transition-colors">
          {content.sozietaet_cta}
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {content.usp_items.map((item: {label: string, desc: string}) => (
          <div class="p-6 bg-white border border-stone-100 shadow-sm rounded-sm">
            <div class="flex items-center gap-2 mb-3">
              <svg width="16" height="16" fill="none" stroke="#4a9fd4" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              <h3 class="font-semibold text-[#0f2c4e] text-sm">{item.label}</h3>
            </div>
            <p class="text-stone-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- KOMPETENZ / RECHTSGEBIETE -->
<section id="kompetenz" class="py-28 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-14">
      <div class="inline-flex items-center gap-2 mb-5">
        <div class="h-px w-8 bg-[#0f2c4e]"></div>
        <span class="text-[#0f2c4e] text-xs tracking-[0.25em] uppercase font-medium">{content.kompetenz_eyebrow}</span>
      </div>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <h2 class="font-serif text-3xl md:text-4xl text-[#0f2c4e] max-w-lg leading-tight">{content.kompetenz_headline}</h2>
        <p class="text-stone-500 text-sm max-w-xs leading-relaxed">{content.kompetenz_subtext}</p>
      </div>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {content.rechtsgebiete.map((rg: {icon: string, title: string, subtitle: string, desc: string, slug: string, tags: string[]}) => (
        <a href={`/leistungen/${rg.slug}`} class="group p-7 border border-stone-100 rounded-sm hover:border-[#4a9fd4] hover:shadow-md transition-all duration-200 block">
          <div class="flex items-start justify-between mb-4">
            <span class="text-2xl">{rg.icon}</span>
            <span class="text-[10px] tracking-widest text-stone-400 uppercase">{rg.subtitle}</span>
          </div>
          <h3 class="font-serif text-xl font-semibold text-[#0f2c4e] mb-3 group-hover:text-[#4a9fd4] transition-colors">{rg.title}</h3>
          <p class="text-stone-500 text-sm leading-relaxed mb-5">{rg.desc}</p>
          {rg.tags && (
            <div class="flex flex-wrap gap-1.5">
              {rg.tags.map((tag: string) => (
                <span class="text-[10px] bg-stone-50 text-stone-500 border border-stone-100 px-2 py-0.5">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </div>
</section>

<!-- PARTNER -->
<section id="partner" class="py-28 bg-[#0f2c4e]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-14">
      <div class="inline-flex items-center gap-2 mb-5">
        <div class="h-px w-8 bg-[#4a9fd4]"></div>
        <span class="text-[#4a9fd4] text-xs tracking-[0.25em] uppercase font-medium">{content.partner_eyebrow}</span>
      </div>
      <h2 class="font-serif text-3xl md:text-4xl text-white leading-tight max-w-xl">{content.partner_headline}</h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {content.partner.map((p: {initials: string, name: string, bio: string, foto?: string, focus: string[]}) => (
        <div class="group p-6 border border-white/10 rounded-sm hover:border-[#4a9fd4]/50 hover:bg-white/5 transition-all duration-200">
          {p.foto ? (
            <img src={p.foto} alt={p.name} class="w-14 h-14 rounded-sm object-cover mb-5" />
          ) : (
            <div class="w-14 h-14 rounded-sm bg-[#4a9fd4]/15 border border-[#4a9fd4]/30 flex items-center justify-center mb-5">
              <span class="font-serif font-bold text-[#4a9fd4] text-lg">{p.initials}</span>
            </div>
          )}
          <h3 class="font-serif text-lg text-white font-semibold mb-2 leading-tight">{p.name}</h3>
          <p class="text-white/50 text-xs leading-relaxed mb-4">{p.bio}</p>
          <div class="space-y-1.5">
            {p.focus.map((f: string) => (
              <div class="flex items-center gap-2">
                <div class="w-1 h-1 rounded-full bg-[#4a9fd4]"></div>
                <span class="text-[11px] text-white/60">{f}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- KARRIERE -->
<section id="karriere" class="py-28 bg-[#f8f5f0]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <div>
        <div class="inline-flex items-center gap-2 mb-5">
          <div class="h-px w-8 bg-[#0f2c4e]"></div>
          <span class="text-[#0f2c4e] text-xs tracking-[0.25em] uppercase font-medium">{content.karriere_eyebrow}</span>
        </div>
        <h2 class="font-serif text-3xl md:text-4xl text-[#0f2c4e] leading-tight mb-6">{content.karriere_headline}</h2>
        <div class="text-stone-600 leading-relaxed mb-8" set:html={content.karriere_text}></div>
        {content.karriere_bild && (
          <img src={content.karriere_bild} alt={content.karriere_bild_alt || 'Karriere bei HSOA'} class="w-full rounded-sm mb-6 object-cover aspect-video" />
        )}
        <div class="flex flex-col gap-3 mb-8">
          {content.karriere_positionen.map((pos: string) => (
            <div class="flex items-center gap-3">
              <svg width="16" height="16" fill="none" stroke="#4a9fd4" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              <span class="text-stone-700 text-sm">{pos}</span>
            </div>
          ))}
        </div>
        <a href={`mailto:${content.email}?subject=Bewerbung HSOA`} class="inline-flex items-center gap-2 px-7 py-3.5 bg-[#0f2c4e] text-white text-sm font-semibold rounded-sm hover:bg-[#0a1e35] transition-colors">
          {content.karriere_cta}
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <div class="pt-2">
        <div class="border-l-2 border-[#4a9fd4] pl-8 space-y-10">
          {content.karriere_schritte.map((s: {nr: string, phase: string, desc: string}) => (
            <div class="relative">
              <div class="absolute -left-[2.75rem] -top-1 w-5 h-5 rounded-full bg-[#4a9fd4] flex items-center justify-center">
                <div class="w-2 h-2 rounded-full bg-white"></div>
              </div>
              <span class="text-[10px] tracking-widest text-[#4a9fd4] uppercase font-medium">{s.nr}</span>
              <h4 class="font-semibold text-[#0f2c4e] text-base mt-1 mb-2">{s.phase}</h4>
              <p class="text-stone-500 text-sm leading-relaxed">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- KONTAKT -->
<section id="kontakt" class="py-28 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16">
      <div>
        <div class="inline-flex items-center gap-2 mb-5">
          <div class="h-px w-8 bg-[#0f2c4e]"></div>
          <span class="text-[#0f2c4e] text-xs tracking-[0.25em] uppercase font-medium">{content.kontakt_eyebrow}</span>
        </div>
        <h2 class="font-serif text-3xl md:text-4xl text-[#0f2c4e] leading-tight mb-6">{content.kontakt_headline}</h2>
        <p class="text-stone-600 leading-relaxed mb-10">{content.kontakt_text}</p>
        <div class="space-y-6">
          <a href={`tel:${content.telefon_link}`} class="flex items-center gap-4 group">
            <div class="w-11 h-11 rounded-sm bg-[#0f2c4e]/5 flex items-center justify-center text-[#0f2c4e] group-hover:bg-[#4a9fd4] group-hover:text-white transition-colors">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92v2z"/></svg>
            </div>
            <div>
              <p class="text-xs text-stone-400 uppercase tracking-wide mb-0.5">Telefon</p>
              <p class="text-[#0f2c4e] font-medium text-sm">{content.telefon}</p>
            </div>
          </a>
          <a href={`mailto:${content.email}`} class="flex items-center gap-4 group">
            <div class="w-11 h-11 rounded-sm bg-[#0f2c4e]/5 flex items-center justify-center text-[#0f2c4e] group-hover:bg-[#4a9fd4] group-hover:text-white transition-colors">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <p class="text-xs text-stone-400 uppercase tracking-wide mb-0.5">E-Mail</p>
              <p class="text-[#0f2c4e] font-medium text-sm">{content.email}</p>
            </div>
          </a>
        </div>
        {content.kontakt_zitat && (
          <div class="mt-10 p-6 bg-[#f8f5f0] border-l-2 border-[#4a9fd4] rounded-r-sm">
            <p class="text-stone-500 text-sm leading-relaxed italic">„{content.kontakt_zitat}"</p>
            {content.kontakt_zitat_autor && <p class="text-[#0f2c4e] font-semibold text-xs mt-3">— {content.kontakt_zitat_autor}</p>}
          </div>
        )}
      </div>
      <div>
        <form name="kontakt" method="POST" data-netlify="true" class="space-y-5">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-medium text-stone-500 uppercase tracking-wide mb-1.5">Name *</label>
              <input name="name" required class="w-full px-4 py-3 border border-stone-200 rounded-sm text-sm focus:outline-none focus:border-[#4a9fd4] transition-colors bg-white" placeholder="Ihr vollständiger Name" />
            </div>
            <div>
              <label class="block text-xs font-medium text-stone-500 uppercase tracking-wide mb-1.5">Unternehmen</label>
              <input name="firma" class="w-full px-4 py-3 border border-stone-200 rounded-sm text-sm focus:outline-none focus:border-[#4a9fd4] transition-colors bg-white" placeholder="Firmenname (optional)" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-medium text-stone-500 uppercase tracking-wide mb-1.5">E-Mail *</label>
              <input type="email" name="email" required class="w-full px-4 py-3 border border-stone-200 rounded-sm text-sm focus:outline-none focus:border-[#4a9fd4] transition-colors bg-white" placeholder="ihre@email.at" />
            </div>
            <div>
              <label class="block text-xs font-medium text-stone-500 uppercase tracking-wide mb-1.5">Telefon</label>
              <input name="telefon" class="w-full px-4 py-3 border border-stone-200 rounded-sm text-sm focus:outline-none focus:border-[#4a9fd4] transition-colors bg-white" placeholder="+43 ..." />
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-stone-500 uppercase tracking-wide mb-1.5">Rechtsgebiet</label>
            <select name="betreff" class="w-full px-4 py-3 border border-stone-200 rounded-sm text-sm focus:outline-none focus:border-[#4a9fd4] transition-colors bg-white text-stone-600">
              <option value="">Bitte wählen ...</option>
              {content.rechtsgebiete.map((rg: {title: string}) => (
                <option value={rg.title}>{rg.title}</option>
              ))}
              <option value="Sonstiges">Sonstiges</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-stone-500 uppercase tracking-wide mb-1.5">Ihre Anfrage *</label>
            <textarea name="nachricht" required rows={5} class="w-full px-4 py-3 border border-stone-200 rounded-sm text-sm focus:outline-none focus:border-[#4a9fd4] transition-colors bg-white resize-none" placeholder="Schildern Sie uns kurz Ihr Anliegen ..."></textarea>
          </div>
          <p class="text-stone-400 text-xs">Alle Angaben werden vertraulich behandelt. Mit dem Absenden stimmen Sie unserer <a href="/datenschutz" class="underline">Datenschutzerklärung</a> zu.</p>
          <button type="submit" class="w-full py-4 bg-[#0f2c4e] text-white text-sm font-semibold rounded-sm hover:bg-[#0a1e35] transition-colors flex items-center justify-center gap-2">
            Anfrage unverbindlich senden
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="bg-[#071528] text-white/40 text-xs">
  <div class="max-w-7xl mx-auto px-6 py-10 flex flex-col md:flex-row justify-between items-start gap-6">
    <div>
      <div class="font-serif text-white/70 font-bold text-base mb-1">{content.kanzlei_kuerzel} Rechtsanwälte</div>
      <p class="leading-relaxed" set:html={content.footer_adresse_html}></p>
    </div>
    <div class="flex flex-wrap gap-6 text-white/40">
      {content.nav_links.map((link: {label: string, href: string}) => (
        <a href={link.href} class="hover:text-white/70 transition-colors">{link.label}</a>
      ))}
      <a href="/impressum" class="hover:text-white/70 transition-colors">Impressum</a>
      <a href="/datenschutz" class="hover:text-white/70 transition-colors">Datenschutz</a>
    </div>
  </div>
  <div class="border-t border-white/5 max-w-7xl mx-auto px-6 py-4 text-[11px] text-white/20">
    © {new Date().getFullYear()} {content.footer_firma}
  </div>
</footer>

</Layout>

